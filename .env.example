# PostgreSQL
POSTGRES_DB=news_collector
POSTGRES_USER=news
POSTGRES_PASSWORD=news
POSTGRES_PORT=5433

# API
API_PORT=5182

# Frontend
FRONTEND_PORT=5190

# Worker
ASPNETCORE_ENVIRONMENT=Production
RUN_MIGRATIONS=true

# Topic linker (same-topic news detection)
TOPIC_LINKER_INTERVAL_SECONDS=60

# Ollama (AI rewrite)
# В Docker API ходит на сервис ollama по внутренней сети: http://ollama:11434
# OLLAMA_PORT — только проброс на хост (11435), чтобы не конфликтовать с Ollama на хосте :11434
# Если API в Docker, а модель на хосте: OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11435
OLLAMA_MODEL=deepseek-r1:14b
OLLAMA_TIMEOUT_SECONDS=600

# Local development (dotnet run outside Docker)
CONNECTION_STRING=Host=localhost;Port=5433;Database=news_collector;Username=news;Password=news
