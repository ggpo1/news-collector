# PostgreSQL
POSTGRES_DB=news_collector
POSTGRES_USER=news
POSTGRES_PASSWORD=news
POSTGRES_PORT=5433

# API
API_PORT=5182

# Frontend
FRONTEND_PORT=5190

# Worker
ASPNETCORE_ENVIRONMENT=Production
RUN_MIGRATIONS=true
RSS_FETCH_TIMEOUT_SECONDS=120

# Topic linker (same-topic news detection)
TOPIC_LINKER_INTERVAL_SECONDS=60

# News categorizer (AI category assignment)
NEWS_CATEGORIZER_INTERVAL_SECONDS=60
NEWS_CATEGORIZER_BATCH_SIZE=10
NEWS_CATEGORIZER_DELAY_MS=200

# News tone analyzer (sentiment coefficient -1..+1)
NEWS_TONE_ANALYZER_INTERVAL_SECONDS=60
NEWS_TONE_ANALYZER_BATCH_SIZE=10
NEWS_TONE_ANALYZER_DELAY_MS=200

# News entity extractor (persons, companies, countries for semantic graph)
NEWS_ENTITY_EXTRACTOR_INTERVAL_SECONDS=60
NEWS_ENTITY_EXTRACTOR_BATCH_SIZE=5
NEWS_ENTITY_EXTRACTOR_DELAY_MS=500
NEWS_ENTITY_EXTRACTOR_MAX_ENTITIES=20

# Ollama NER (entity-extractor)
OLLAMA_NER_BASE_URL=http://ollama-ner:11434
OLLAMA_NER_PORT=11436
OLLAMA_NER_MODEL=llama3.2:3b
OLLAMA_NER_TIMEOUT_SECONDS=600

# Ollama categorizer (news-categorizer)
OLLAMA_CATEGORIZER_BASE_URL=http://ollama-categorizer:11434
OLLAMA_CATEGORIZER_PORT=11437
OLLAMA_CATEGORIZER_MODEL=llama3.2:3b
OLLAMA_CATEGORIZER_TIMEOUT_SECONDS=600

# Ollama tone (news-tone-analyzer)
OLLAMA_TONE_BASE_URL=http://ollama-tone:11434
OLLAMA_TONE_PORT=11438
OLLAMA_TONE_MODEL=llama3.2:3b
OLLAMA_TONE_TIMEOUT_SECONDS=600

# Ollama (AI rewrite в API — тяжёлая модель)
# В Docker API ходит на сервис ollama по внутренней сети: http://ollama:11434
# OLLAMA_PORT — только проброс на хост (11435), чтобы не конфликтовать с Ollama на хосте :11434
# Если API в Docker, а модель на хосте: OLLAMA_BASE_URL=http://host.docker.internal:11434
# Тяжёлые модели (deepseek-r1:14b) могут отвечать 5–15+ минут — таймаут 1800 с (nginx + API + Ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11435
OLLAMA_MODEL=deepseek-r1:14b
OLLAMA_TIMEOUT_SECONDS=1800

# Auth (JWT)
AUTH_JWT_SECRET=change-this-secret-in-production-min-32-characters-long
AUTH_JWT_EXPIRATION_MINUTES=480
AUTH_SEED_CHIEF_LOGIN=chief
AUTH_SEED_CHIEF_PASSWORD=changeme
AUTH_SEED_CHIEF_DISPLAY_NAME=Главный редактор

# Local development (dotnet run outside Docker)
CONNECTION_STRING=Host=localhost;Port=5433;Database=news_collector;Username=news;Password=news

# Telegram bots (Docker orchestrator from API)
TELEGRAM_ORCHESTRATOR_ENABLED=true
TELEGRAM_BOT_IMAGE=news-collector-telegram-bot:latest
# Имя docker-сети compose-проекта (docker network ls)
DOCKER_NETWORK=news-collector_default
# Прокси для воркеров Telegram (Xray HTTP inbound на хосте, порт 10809).
# SOCKS5 (10808) .NET HttpClient не поддерживает — только HTTP proxy.
# После настройки Xray: sudo ./scripts/setup-xray-docker-proxy.sh
# TELEGRAM_WORKER_HTTP_PROXY=http://host.docker.internal:10809
# TELEGRAM_WORKER_HTTPS_PROXY=http://host.docker.internal:10809
# API в контейнере: 0:0 = root, нужен для docker.sock если на хосте только sudo docker
API_CONTAINER_USER=0:0
# Если API_CONTAINER_USER не root — укажите GID группы docker: getent group docker | cut -d: -f3
# DOCKER_GID=999
