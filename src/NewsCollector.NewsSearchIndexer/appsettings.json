{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=news_collector;Username=news;Password=news"
  },
  "NewsSearchIndexer": {
    "PollingIntervalSeconds": 30,
    "BatchSize": 25,
    "DelayBetweenItemsMs": 0,
    "MaxBodyCharacters": 8000
  },
  "EditorialBrief": {
    "RuSourcePatterns": [".ru", "ria.ru", "tass.ru", "rbc.ru"],
    "WesternSourcePatterns": ["reuters", "bbc.", "theguardian", "nytimes"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
