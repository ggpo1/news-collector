  "Ollama": {
    "BaseUrl": "http://localhost:11436",
    "Model": "llama3.2:3b",
    "TimeoutSeconds": 600
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
